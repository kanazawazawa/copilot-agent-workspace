@page "/"
@using CopilotWebApp.Services
@inject GitHubActionsService GitHub
@inject BlobStorageService BlobStorage
@inject IJSRuntime JS
@inject IConfiguration Configuration
@rendermode InteractiveServer

<PageTitle>Copilot Slide Generator</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">🤖 Copilot プロンプト入力</h4>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="prompt" class="form-label fw-bold">プロンプト</label>
                        <textarea @bind="prompt" id="prompt" class="form-control" rows="6"
                                  placeholder="@placeholderText"></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="model" class="form-label fw-bold">モデル</label>
                        <select @bind="selectedModel" id="model" class="form-select">
                            <optgroup label="Anthropic">
                                <option value="claude-opus-4.6">Claude Opus 4.6 (3x)</option>
                                <option value="claude-opus-4.6-fast">Claude Opus 4.6 Fast (30x)</option>
                                <option value="claude-opus-4.5">Claude Opus 4.5 (3x)</option>
                                <option value="claude-sonnet-4.6">Claude Sonnet 4.6 (1x)</option>
                                <option value="claude-sonnet-4.5">Claude Sonnet 4.5 (1x)</option>
                                <option value="claude-sonnet-4">Claude Sonnet 4 (1x)</option>
                                <option value="claude-haiku-4.5">Claude Haiku 4.5 (0.33x)</option>
                            </optgroup>
                            <optgroup label="OpenAI">
                                <option value="gpt-5.4">GPT-5.4 (1x)</option>
                                <option value="gpt-5.3-codex">GPT-5.3-Codex (1x)</option>
                                <option value="gpt-5.2-codex">GPT-5.2-Codex (1x)</option>
                                <option value="gpt-5.2">GPT-5.2 (1x)</option>
                                <option value="gpt-5.1-codex-max">GPT-5.1-Codex-Max (1x)</option>
                                <option value="gpt-5.1-codex">GPT-5.1-Codex (1x)</option>
                                <option value="gpt-5.1-codex-mini">GPT-5.1-Codex-Mini (0.33x)</option>
                                <option value="gpt-5.1">GPT-5.1 (1x)</option>
                                <option value="gpt-5-mini">GPT-5 mini (0x)</option>
                                <option value="gpt-4.1">GPT-4.1 (0x)</option>
                            </optgroup>
                            <optgroup label="Google">
                                <option value="gemini-3-pro-preview">Gemini 3 Pro (1x)</option>
                            </optgroup>
                        </select>
                    </div>

                    <button @onclick="RunWorkflow" class="btn btn-primary btn-lg w-100"
                            disabled="@(isRunning || string.IsNullOrWhiteSpace(prompt))">
                        @if (isRunning)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>実行中...</span>
                        }
                        else
                        {
                            <span>▶ 実行</span>
                        }
                    </button>

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert @statusCss mt-3 mb-0" role="alert">
                            @statusMessage
                        </div>
                    }

                    @* 実行キー入力ダイアログ *@
                    @if (showExecKeyDialog)
                    {
                        <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">実行キー</h5>
                                        <button type="button" class="btn-close" @onclick="CloseExecKeyDialog"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="input-group">
                                            <input type="password" class="form-control" placeholder="実行キー" @bind="execKeyInput"
                                                   @onkeydown="ExecKeyKeyDown" />
                                        </div>
                                        @if (execKeyError)
                                        {
                                            <div class="text-danger small mt-2">キーが一致しません</div>
                                        }
                                    </div>
                                    <div class="modal-footer">
                                        <button class="btn btn-secondary btn-sm" @onclick="CloseExecKeyDialog">キャンセル</button>
                                        <button class="btn btn-primary btn-sm" @onclick="SubmitExecKey">実行</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">📋 テンプレート</h5>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var tpl in templates)
                    {
                        <button class="list-group-item list-group-item-action" @onclick="() => ApplyTemplate(tpl)">
                            @tpl.Name
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- PPTX 履歴テーブル -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">📚 作成履歴</h5>
                    <div class="d-flex align-items-center gap-2">
                        <div class="input-group input-group-sm" style="width: 260px;">
                            <span class="input-group-text">🔍</span>
                            <input type="text" class="form-control" placeholder="キーワードで絞り込み..."
                                   @bind="historyFilter" @bind:event="oninput" />
                            @if (!string.IsNullOrEmpty(historyFilter))
                            {
                                <button class="btn btn-outline-secondary" @onclick="() => historyFilter = string.Empty">✕</button>
                            }
                        </div>
                        <button @onclick="RefreshHistory" class="btn btn-outline-primary btn-sm" disabled="@isHistoryLoading">
                            @if (isHistoryLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            🔄 更新
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (historyFiles == null)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border spinner-border-sm text-primary"></div>
                            <span class="ms-2 text-muted">読み込み中...</span>
                        </div>
                    }
                    else if (historyFiles.Count == 0 && (inProgressRuns == null || inProgressRuns.Count == 0))
                    {
                        <div class="text-muted text-center py-4">まだ PPTX ファイルがありません</div>
                    }
                    else
                    {
                        var filtered = FilteredHistoryFiles;
                        var filteredInProgress = FilteredInProgressRuns;
                        @if (!string.IsNullOrEmpty(historyFilter))
                        {
                            <div class="px-3 pt-2">
                                <small class="text-muted">@(filtered.Count + filteredInProgress.Count) / @(historyFiles.Count + (inProgressRuns?.Count ?? 0)) 件がヒット</small>
                            </div>
                        }
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>作成日</th>
                                    <th>プロンプト</th>
                                    <th>ファイル名</th>
                                    <th style="width:120px">ダウンロード</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var run in filteredInProgress)
                                {
                                    <tr class="table-warning">
                                        <td class="text-nowrap">
                                            @run.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                                        </td>
                                        <td class="small" style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@run.Prompt">
                                            @(string.IsNullOrEmpty(run.Prompt) ? "—" : run.Prompt)
                                        </td>
                                        <td>
                                            <span class="badge @(run.Status == "queued" ? "bg-secondary" : "bg-warning text-dark")">
                                                <span class="spinner-border spinner-border-sm me-1" style="width: 0.7rem; height: 0.7rem;"></span>
                                                @(run.Status == "queued" ? "🕐 待機中" : "⚙️ 作成中")
                                            </span>
                                        </td>
                                        <td>
                                            <a href="@run.HtmlUrl" target="_blank" class="btn btn-outline-secondary btn-sm">GitHub ↗</a>
                                        </td>
                                    </tr>
                                }
                                @foreach (var file in filtered)
                                {
                                    <tr>
                                        <td class="text-nowrap">
                                            @(file.LastModified.HasValue
                                                ? file.LastModified.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                                                : "—")
                                        </td>
                                        <td class="small text-muted" style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@file.Prompt">
                                            @(string.IsNullOrEmpty(file.Prompt) ? "—" : file.Prompt)
                                        </td>
                                        <td>@file.FileName</td>
                                        <td>
                                            <button class="btn btn-primary btn-sm"
                                                    @onclick="() => DownloadHistoryFile(file)"
                                                    disabled="@(downloadingBlob == file.BlobName)">
                                                @if (downloadingBlob == file.BlobName)
                                                {
                                                    <span class="spinner-border spinner-border-sm"></span>
                                                }
                                                else
                                                {
                                                    <span>⬇</span>
                                                }
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string prompt = "";
    private string selectedModel = "claude-opus-4.6";
    private bool isRunning = false;
    private string statusMessage = "";
    private string statusCss = "alert-info";
    private bool showExecKeyDialog = false;
    private string execKeyInput = "";
    private bool execKeyError = false;
    private bool isAuthenticated = false;

    private const string placeholderText =
        "例: Azure の ○○ について提案書を PPTX で作成して\n" +
        "例: Azure Cosmos DB の概要を PPTX にまとめてください\n" +
        "例: Azure Container Apps の VNET 構成について PPTX にまとめてください\n" +
        "例: Microsoft Foundry Models のデプロイ種別を比較表付きで PPTX にまとめて\n" +
        "例: Foundry Agent Service について提案・プレゼン用に詳細な PPTX を作成して";

    private record PromptTemplate(string Name, string Prompt);

    private readonly List<PromptTemplate> templates = new()
    {
        new("Azure App Service",
            "Azure App Service の概要を PPTX でまとめてください。"),
        new("Azure Cosmos DB",
            "Azure Cosmos DB の概要を PPTX でまとめてください。"),
        new("Azure Container Apps",
            "Azure Container Apps の概要を PPTX でまとめてください。"),
        new("Foundry Models デプロイ種別",
            "Microsoft Foundry Models のデプロイ種別についてわかりやすく PPTX にまとめてください。各デプロイ種別の特徴、課金体系、ユースケース、対応モデルを含めてください。"),
        new("Foundry Agent Service",
            "Microsoft Foundry Agent Service について、提案・プレゼン用に詳細な PPTX を作成してください。"),
    };

    private async Task RunWorkflow()
    {
        // Cookie チェック → 認証済みならそのまま実行、未認証ならダイアログ表示
        if (!isAuthenticated)
        {
            var cookie = await JS.InvokeAsync<string>("getCookie", "exec_key_verified");
            if (cookie == "true")
            {
                isAuthenticated = true;
            }
            else
            {
                showExecKeyDialog = true;
                execKeyInput = "";
                execKeyError = false;
                StateHasChanged();
                return;
            }
        }

        await ExecuteWorkflow();
    }

    private async Task SubmitExecKey()
    {
        var expectedKey = Configuration["ExecKey"] ?? "";
        if (execKeyInput == expectedKey)
        {
            isAuthenticated = true;
            execKeyError = false;
            showExecKeyDialog = false;

            // Cookie に保存（30日間）
            await JS.InvokeVoidAsync("setCookie", "exec_key_verified", "true", 30);

            await ExecuteWorkflow();
        }
        else
        {
            execKeyError = true;
            StateHasChanged();
        }
    }

    private async Task ExecKeyKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitExecKey();
        }
    }

    private void CloseExecKeyDialog()
    {
        showExecKeyDialog = false;
        execKeyError = false;
    }

    private async Task ExecuteWorkflow()
    {
        isRunning = true;
        statusMessage = "ワークフローをトリガーしています...";
        statusCss = "alert-info";
        StateHasChanged();

        try
        {
            var success = await GitHub.TriggerWorkflowAsync(prompt, selectedModel);
            if (success)
            {
                statusMessage = "✅ ワークフローを開始しました！ジョブ一覧ページで進捗を確認してください。";
                statusCss = "alert-success";
            }
            else
            {
                statusMessage = "❌ ワークフローの開始に失敗しました。設定を確認してください。";
                statusCss = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"❌ エラー: {ex.Message}";
            statusCss = "alert-danger";
        }
        finally
        {
            isRunning = false;
        }
    }

    private void ApplyTemplate(PromptTemplate tpl)
    {
        prompt = tpl.Prompt;
    }

    // --- 履歴テーブル ---
    private List<PptxFileInfo>? historyFiles;
    private List<InProgressRunInfo>? inProgressRuns;
    private bool isHistoryLoading = false;
    private string? downloadingBlob;
    private string historyFilter = string.Empty;

    private List<PptxFileInfo> FilteredHistoryFiles =>
        string.IsNullOrWhiteSpace(historyFilter) || historyFiles == null
            ? historyFiles ?? new()
            : historyFiles.Where(f =>
                (f.FileName?.Contains(historyFilter, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (f.Prompt?.Contains(historyFilter, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (f.RelativePath?.Contains(historyFilter, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();

    private List<InProgressRunInfo> FilteredInProgressRuns =>
        inProgressRuns == null ? new()
        : string.IsNullOrWhiteSpace(historyFilter) ? inProgressRuns
        : inProgressRuns.Where(r =>
            r.Prompt?.Contains(historyFilter, StringComparison.OrdinalIgnoreCase) ?? false
        ).ToList();

    protected override async Task OnInitializedAsync()
    {
        await RefreshHistory();
    }

    private async Task RefreshHistory()
    {
        isHistoryLoading = true;
        StateHasChanged();

        try
        {
            var historyTask = BlobStorage.ListAllPptxAsync();
            var inProgressTask = GitHub.GetInProgressRunsAsync();
            await Task.WhenAll(historyTask, inProgressTask);

            historyFiles = historyTask.Result;
            inProgressRuns = inProgressTask.Result;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"RefreshHistory error: {ex.Message}");
            historyFiles ??= new();
            inProgressRuns ??= new();
        }

        isHistoryLoading = false;
        StateHasChanged();
    }

    private async Task DownloadHistoryFile(PptxFileInfo file)
    {
        downloadingBlob = file.BlobName;
        StateHasChanged();

        try
        {
            var data = await BlobStorage.DownloadBlobAsync(file.BlobName);
            if (data != null)
            {
                var base64 = Convert.ToBase64String(data);
                var mimeType = "application/vnd.openxmlformats-officedocument.presentationml.presentation";
                await JS.InvokeVoidAsync("downloadFile", file.FileName, base64, mimeType);
            }
        }
        finally
        {
            downloadingBlob = null;
            StateHasChanged();
        }
    }
}
